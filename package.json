{
  "name": "leerness",
  "version": "1.36.42",
  "description": "The AI-coding operations layer that makes \"done\" require evidence — persistent memory, evidence-gated completion checks, and clean handoffs for any AI agent (Claude Code, Codex, Cursor). State lives as plain files in your repo. CLI + MCP, 0 runtime dependencies.",
  "keywords": [
    "leerness",
    "ai",
    "agent",
    "harness",
    "context-engineering",
    "claude",
    "claude-code",
    "cursor",
    "copilot",
    "skill-library",
    "project-memory",
    "task-tracking",
    "planning",
    "handoff",
    "anti-laziness",
    "encoding",
    "secret-scan",
    "auto-update",
    "design-system",
    "developer-tools",
    "korean"
  ],
  "license": "MIT",
  "author": "leerness contributors",
  "type": "commonjs",
  "main": "bin/leerness.js",
  "preferGlobal": true,
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "leerness": "bin/leerness.js"
  },
  "files": [
    "bin",
    "lib",
    "scripts",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node ./bin/leerness.js --version && node ./bin/leerness.js selftest && node ./scripts/e2e.js",
    "test:core": "node ./bin/leerness.js --version && node ./bin/leerness.js selftest && node ./scripts/e2e-core.js",
    "test:fast": "node ./bin/leerness.js selftest && node ./scripts/smoke.js",
    "test:smoke": "node ./scripts/smoke.js",
    "prepack": "node ./bin/leerness.js readme sync . && node ./bin/leerness.js --version"
  },
  "publishConfig": {
    "access": "public"
  }
}
